---
import Bento from "../../components/Bento.astro";
import CTA from "../../components/services/CTA.astro";
import { SITE_TITLE } from "../../consts";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/services/Hero.astro";
import mountains from "../../assets/services/asheville-mountains.jpeg";

import strategyImg from "../../assets/strategy.jpg";
import architectureImg from "../../assets/architecture.jpg";
import mapImg from "../../assets/map.jpg";
import teamImg from "../../assets/team.jpg";
import riskImg from "../../assets/risk.jpg";

const title = `Fractional CTO for Startups | ${SITE_TITLE}`;
const description =
  "Expert technical leadership—without the full-time cost. I help early-stage founders move fast, avoid costly mistakes, and build tech that scales.";

const bentoCards = [
  {
    img: strategyImg,
    headline: "Strategy",
    title: "Define and validate your technical strategy",
    desc: "Get a clear, actionable plan for your product and tech stack.",
  },
  {
    img: architectureImg,
    headline: "Architecture",
    title: "Architect systems that scale",
    desc: "Build a foundation that grows with your business.",
  },
  {
    img: mapImg,
    headline: "Roadmap",
    title: "Translate vision into an actionable roadmap",
    desc: "Turn ideas into milestones and deliverables.",
  },
  {
    img: teamImg,
    headline: "Team",
    title: "Guide hiring and mentor your team",
    desc: "Interview technical talent and level up your developers.",
  },
  {
    img: riskImg,
    headline: "Risk",
    title: "Spot risks before they become problems",
    desc: "Proactive risk management saves time and money.",
  },
];
---

<BaseLayout title={title} description={description}>
  <Hero
    title="Fractional CTO for Startups"
    description="Expert technical leadership—without the full-time cost. I help early-stage founders move fast, avoid costly mistakes, and build tech that scales. Many early-stage startups start with a great idea and quick code, but scaling that idea into a business takes more than just development—it requires technical strategy, product foresight, and leadership. As your Fractional CTO, I bridge the gap between vision and execution so you can focus on growing your business."
    image={mountains}
    imageAlt="View of mountains in Asheville, NC. Taken by me."
  />

  <section class="py-4 bg-secondary">
    <div class="container mx-auto px-4">
      <Bento
        sectionHeadline="Fractional CTO Benefits"
        sectionTitle="How I help founders and startups succeed"
        cards={bentoCards}
      />
    </div>
  </section>

  <section class="py-16 bg-background">
    <div class="container mx-auto px-4 flex flex-col items-center">
      <CTA
        headline="Let’s Talk About Your Startup"
        text="If you’ve started building but need help making it real, let’s chat. I offer a free consult to understand your challenges and see if I’m the right fit."
        buttonText="Book a Free Consult"
      />
    </div>
  </section>
</BaseLayout>

