---
import Icon from "../Icon.tsx";
import { IconName } from "../Icon.tsx";
const services = [
  {
    title: "Fractional CTO & Technical Advisory",
    subhead: "Strategic leadership, technical roadmapping, mentoring, and team guidance.",
    iconName:IconName.CONSULTING,
    href: "/services/fractional-cto",
  },
];
---

<div class="bg-background py-24 sm:py-32">
  <div
    class="mx-auto grid max-w-7xl gap-x-8 gap-y-20 px-6 lg:px-8 xl:grid-cols-3"
  >
    <div class="max-w-2xl">
      <h2 class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
        How can I help?
      </h2>
      <p class="mt-6 text-lg leading-8 text-secondary-foreground">
        I'm currently building my own applications and offering my expertise and
        experience to others.
      </p>
    </div>
    <ul
      role="list"
      class="grid gap-x-8 gap-y-12 sm:grid-cols-2 sm:gap-y-16 xl:col-span-2"
    >
      {
        services.map((service) => (
          <a href={service.href} class="block">
            <li class="hover:border-secondary border border-transparent hover:shadow-xl dark:hover:shadow-black/40 transition-all hover:cursor-pointer p-4 rounded-xl">
              <Icon name={service.iconName} />
              <div>
                <h3 class="text-base font-semibold leading-7 tracking-tight text-foreground">
                  {service.title}
                </h3>
                <p class="text-sm font-semibold leading-6 text-highlight">
                  {service.subhead}
                </p>
              </div>
            </li>
          </a>
        ))
      }
    </ul>
  </div>
</div>
