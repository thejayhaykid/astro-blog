---
type TableRow = Record<string, unknown>;
type TableGroup = {
  name: string;
  rows: TableRow[];
};

interface Props {
  title?: string;
  subTitle?: string;
  description?: string;
  buttonLabel?: string;
  groups: TableGroup[];
}

const {
  title = "Table",
  subTitle = "",
  description = "",
  groups = [],
}: Props = Astro.props;

const columnKeys =
  groups.length > 0 && groups[0].rows.length > 0
    ? Object.keys(groups[0].rows[0])
    : [];
---

<div class="px-4 sm:px-6 lg:px-8">
  <div class="sm:flex sm:items-center">
    <div class="sm:flex-auto">
      <h1 class="text-4xl font-semibold text-foreground">{title}</h1>
      {
        subTitle && (
          <h3 class="text-xl font-semibold text-foreground">{subTitle}</h3>
        )
      }
      {
        description && (
          <p class="mt-2 max-w-2xl text-sm text-secondary-foreground">
            {description}
          </p>
        )
      }
    </div>
  </div>
  <div class="mt-8 flow-root">
    <div class="-mx-4 -my-2 overflow-x-auto sm:-mx-6 lg:-mx-8">
      <div class="inline-block min-w-full py-2 align-middle sm:px-6 lg:px-8">
        <table class="relative min-w-full">
          <thead class="sr-only bg-background md:not-sr-only md:table-header-group">
            <tr>
              {
                columnKeys.map((key) => (
                  <th
                    scope="col"
                    class="px-3 py-3.5 text-left text-sm font-semibold text-foreground"
                  >
                    {key.charAt(0).toUpperCase() + key.slice(1)}
                  </th>
                ))
              }
            </tr>
          </thead>
          <tbody class="bg-background">
            {
              groups.map((group) => (
                <>
                  <tr class="border-t border-secondary">
                    <th
                      scope="colgroup"
                      colspan={columnKeys.length > 0 ? columnKeys.length : 1}
                      class="bg-secondary py-2 pr-3 pl-4 text-left text-sm font-semibold text-secondary-foreground sm:pl-3"
                    >
                      {group.name}
                    </th>
                  </tr>
                  {group.rows.map((row) => (
                    <tr class="mt-4 block rounded-xl border border-secondary bg-background text-foreground even:bg-secondary/40 md:mt-0 md:table-row md:rounded-none md:border-x-0 md:border-b-0 md:border-t">
                      {columnKeys.map((key) => (
                        <td class="block px-4 py-3 text-sm md:table-cell md:px-3 md:py-4">
                          <div class="flex items-start justify-between gap-4 md:block">
                            <span class="text-xs font-semibold tracking-wide text-muted-foreground uppercase md:hidden">
                              {key}
                            </span>
                            <span class="block flex-1 text-right leading-6 break-words md:text-left">
                              {row[key]}
                            </span>
                          </div>
                        </td>
                      ))}
                    </tr>
                  ))}
                </>
              ))
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
